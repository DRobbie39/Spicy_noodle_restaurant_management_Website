@{
    ViewBag.Title = "Account";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page_title_inner baseline">
    <h1 style="font-family: reforma_2018blanca; ">
        <span class="ppb_title_first">My</span>account
    </h1>
</div>
<div class="row">
    <div class="col-xl-3">
        <ul class="cars">
            <li><a href="/Myaccount/Index">Trang tài khoảng</a></li>
            <li><a href="/Myaccount/Donhang">Đơn hàng</a></li>
            <li><a href="/Myaccount/Tinhtrang">Tình trạng đơn</a></li>
            <li><a href="/Myaccount/Account" class="bxx">Tài khoảng</a></li>
            <li><a href="#">Log out</a></li>
        </ul>
    </div>
    <div class="col-xl-7">
        <div class="card">
            <div class="card-body">
                <form class="mt-3">
                    <div class="form-group">
                        <small id="name" class="form-text text-muted">Tên khách hàng</small>
                        <input type="text" class="form-control" id="nametext" aria-describedby="name"
                               placeholder="Name">
                    </div>
                    <div class="form-group">
                        <small id="name" class="form-text text-muted">Số điện thoại</small>
                        <input type="text" class="form-control" id="nametext" aria-describedby="name"
                               placeholder="Name">
                    </div>
                    <div class="form-group">
                        <small id="name" class="form-text text-muted">Ngày sinh</small>
                        <input type="date" class="form-control" value="2018-05-13">
                    </div>
                    <div class="form-group">
                        <small id="name" class="form-text text-muted">Địa chỉ</small>
                        <input type="text" class="form-control" id="nametext" aria-describedby="name"
                               placeholder="Name">
                    </div>
                    <div class="form-group">
                        <small id="name" class="form-text text-muted">Giới tính</small>
                        <select class="form-control" id="exampleFormControlSelect1">
                            <option>Nam</option>
                            <option>Nữ</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <small id="name" class="form-text text-muted">Mật khẩu hiện tại(Bỏ trống nếu không đổi)</small>
                        <input type="password" class="form-control" value="Name">
                    </div>
                    <div class="form-group">
                        <small id="name" class="form-text text-muted">Mật khẩu mới(Bỏ trống nếu không đổi)</small>
                        <input type="password" class="form-control" value="Name">
                    </div>
                </form>
            </div>
            <button type="submit" class="button" name="save_account_details" value="Lưu thay đổi">Lưu thay đổi</button>
        </div>
    </div>
</div>

<style>
    .button {
        max-width: 150px;
        font-family: reforma_2018blanca;
        font-weight: 700;
        padding: 5px 10px 5px 10px;
        background-color: #38bdf2;
        border: 0;
        border-radius: 4px 4px 4px 4px;
        margin-left: 330px;
    }

    .row {
        margin: 30px;
    }

    .ppb_title_first {
        font-family: reforma_2018blanca;
        line-height: 50px;
        color: #ca9c5e;
    }

    .ppb_title_first {
        display: block;
        font-style: italic;
        font-size: 70px;
        text-transform: none;
        top: 0;
        position: relative;
        letter-spacing: 0 !important;
        font-weight: 400;
    }

    .h1 {
        font-family: inherit !important;
    }

    .baseline {
        text-align: center;
        margin-top: 50px;
    }

    input {
        border-radius: 5px 5px 5px 5px;
    }

    body {
        font-family: reforma_2018blanca;
    }

    .card {
        border-radius: 4px 4px 4px 4px;
        border: 0px solid #000000;
    }

    .text-muted {
        color: #687178 !important;
        font-weight: 700;
        font-size: 1em;
        margin-left: 5px;
    }

    .form-group {
        margin-top: 15px;
    }

    .cars {
        margin-top: 70px;
    }

    a {
        font-size: 20px;
        color: #ca9c5e;
    }

    li a:hover {
        color: #000;
    }

    .bxx {
        background-color: #8fe3b3;
        padding-right: 40px;
        padding-left: 5px;
        border-radius: 3px 3px 3px 3px;
    }

    p {
        font-size: 20px;
        color: #000;
    }
</style>