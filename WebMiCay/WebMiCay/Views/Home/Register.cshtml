
@{
    ViewBag.Title = "Login";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="https://unicons.iconscout.com/release/v2.1.9/css/unicons.css">
<link href="~/Client/css/stylelogin.css" rel="stylesheet" />
<script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>

<body>
    <div class="section">
        <div class="container">
            <div class="row full-height justify-content-center">
                <div class="col-12 text-center align-self-center py-5">
                    <div class="section pb-5 pt-5 pt-sm-2 text-center">
                        <div class="center-wrap">
                            <div class="section text-center">
                                <form method="post">
                                    <h4 class="mb-3 pb-3" style="color: #000">Đăng ký</h4>
                                    <div class="form-group">
                                        <input type="text" name="TenKH" class="form-style" placeholder="Họ tên">
                                        <i class="input-icon uil uil-user"></i>
                                    </div>
                                    <div class="form-group mt-2">
                                        <input type="tel" name="SDT" class="form-style" placeholder="Số điện thoại">
                                        <i class="input-icon uil uil-phone"></i>
                                    </div>
                                    <div class="form-group mt-2">
                                        <input type="datetime" name="NgaySinh" class="form-style" placeholder="Ngày sinh">
                                        <i><iconify-icon class="input-icon" icon="uiw:date" style="margin-top:8px;"></iconify-icon></i>
                                    </div>
                                    <div class="form-group mt-2">
                                        <input type="text" name="DiaChi" class="form-style" placeholder="Địa chỉ">
                                        <i><iconify-icon icon="carbon:map" class="input-icon" style="margin-top:8px;"></iconify-icon></i>
                                    </div>
                                    <div class="form-group mt-2">
                                        <input type="text" name="GioiTinh" class="form-style" placeholder="Giới tính">
                                        <i><iconify-icon icon="ph:gender-intersex" class="input-icon" style="margin-top:8px;"></iconify-icon></i>
                                    </div>
                                    <div class="form-group mt-2">
                                        <input type="text" name="Username" class="form-style" placeholder="Username">
                                        <i class="input-icon uil uil-at"></i>
                                    </div>
                                    <div class="form-group mt-2">
                                        <input type="password" name="MatKhau" class="form-style" placeholder="Mật khẩu">
                                        <i class="input-icon uil uil-lock-alt"></i>
                                    </div>
                                    <button type="submit" class="btn mt-4 ">Đăng ký</button>
                                    <a href="/Home/Login">Đăng nhập ngay?</a>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>

@*<script src="~/Client/js/loginn.js"></script>*@
@*<script src="~/Client/js/signup.js"></script>*@

<style>
    body {
        background-color: #fff;
        color: #544e39;
    }

    .checkbox:checked + label, .checkbox:not(:checked) + label {
        background-color: #000;
    }

    .card-front, .card-back {
        background-color: #fff;
        border: 1px solid #0026ff;
    }

    .form-style {
        background-color: #fff;
    }

    .btn {
        background-color: #0fabff;
    }

    .link {
        color: #2f2d23;
    }

    .card-3d-wrap {
        width: 540px;
        height: 600px;
    }
</style>


